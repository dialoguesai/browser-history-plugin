{
    "manifest_version": 3,
    "name": "URL Logger to Supabase",
    "version": "1.0.0",
    "description": "Logs every visited URL into a Supabase table",
    "permissions": [
        "webNavigation",
        "storage",
        "tabs",
        "notifications"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "options_page": "options.html",
    "icons": {
        "48": "icons/icon-48.png"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}